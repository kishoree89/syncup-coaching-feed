// Prisma schema for SYNCUP coaching feed.
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A single coaching post in the feed.
model Feed {
  id        String   @id @default(cuid())
  title     String
  content   String
  author    String   @default("Coach")
  createdAt DateTime @default(now())

  // We always sort by createdAt DESC, so index it.
  @@index([createdAt])
}
