generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Feed {
  id        String   @id @default(cuid())
  title     String
  content   String
  author    String   @default("Coach")
  createdAt DateTime @default(now())

  @@index([createdAt])
}
