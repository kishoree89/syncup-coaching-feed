# Copy this file to .env and adjust values for your local setup.

PORT=4000

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/syncup?schema=public"

# Redis connection string used by ioredis.
REDIS_URL="redis://localhost:6379"

# Allowed origin for CORS and Socket.IO (Next.js dev server).
CORS_ORIGIN="http://localhost:3000"

# Redis cache key + TTL (seconds) for the feed list.
FEED_CACHE_KEY="feed:list"
FEED_CACHE_TTL=60
